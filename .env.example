# F1 Race Engineer MCP Configuration
# Copy this file to .env and customize

# ========================================
# LLM Configuration (Optional)
# ========================================

# Leave empty to use built-in fallback responses
# Or configure your preferred LLM provider:

# OpenAI
# LLM_ENDPOINT=https://api.openai.com/v1/chat/completions
# LLM_API_KEY=sk-your-openai-api-key

# Anthropic Claude
# LLM_ENDPOINT=https://api.anthropic.com/v1/messages
# LLM_API_KEY=sk-ant-your-anthropic-key

# Azure OpenAI
# LLM_ENDPOINT=https://your-resource.openai.azure.com/openai/deployments/your-deployment/chat/completions?api-version=2023-05-15
# LLM_API_KEY=your-azure-api-key

# Local Ollama
# LLM_ENDPOINT=http://localhost:11434/api/generate
# LLM_API_KEY=

# Local LM Studio
# LLM_ENDPOINT=http://localhost:1234/v1/chat/completions
# LLM_API_KEY=not-needed

LLM_ENDPOINT=
LLM_API_KEY=

# ========================================
# Server Configuration
# ========================================

MCP_PORT=8765
TELEMETRY_HOST=host.docker.internal
TELEMETRY_PORT=4768
LOG_LEVEL=INFO

# ========================================
# Voice Integration (Future)
# ========================================

# VOICE_ENABLED=false
# STT_PROVIDER=whisper
# TTS_PROVIDER=elevenlabs
# TTS_API_KEY=
