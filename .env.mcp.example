# F1 Race Engineer MCP Configuration

# LLM Configuration (Required for AI responses)
# Use OpenRouter for access to multiple models
LLM_ENDPOINT=https://openrouter.ai/api/v1/chat/completions
LLM_API_KEY=your_api_key_here
LLM_MODEL=openai/gpt-4o-mini

# Alternative: Use OpenAI directly
# LLM_ENDPOINT=https://api.openai.com/v1/chat/completions
# LLM_API_KEY=your_openai_key
# LLM_MODEL=gpt-4o-mini

# Alternative: Use Anthropic Claude
# LLM_ENDPOINT=https://openrouter.ai/api/v1/chat/completions
# LLM_API_KEY=your_openrouter_key
# LLM_MODEL=anthropic/claude-3.5-sonnet

# Port Configuration
HTTP_PORT=80
HTTPS_PORT=443
MCP_PORT=8765

# Logging
LOG_LEVEL=INFO

# Pits N Giggles Configuration
# If running Pits N Giggles on host (default)
TELEMETRY_HOST=host.docker.internal
TELEMETRY_PORT=4768

# If running Pits N Giggles in Docker (uncomment and configure docker-compose)
# TELEMETRY_HOST=pits-n-giggles
# TELEMETRY_PORT=4768
