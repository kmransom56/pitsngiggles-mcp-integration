%% ===========================================================================
%% Primary Telemetry Flow
%% ===========================================================================
F1_SIM ==>|"UDP Packets"| UDP_RECV
UDP_RECV ==> PARSERS ==> COMP_ENGINE ==> SHARED_STATE
UDP_RECV -.->|"Forward"| PACKET_FWD -.-> EXT_TGT

%% ===========================================================================
%% Core State Fan-out
%% ===========================================================================
SHARED_STATE ==> API_INTF
API_INTF ==> HTTP
API_INTF ==> SOCKETIO
API_INTF ==> ZMQ_PUB

%% ===========================================================================
%% MCP Integration
%% ===========================================================================
HTTP ==>|"/telemetry-info<br/>/race-info"| MCP_API
SHARED_STATE -.->|"Real-time data"| TELEMETRY_ANALYZER

TELEMETRY_ANALYZER --> SETUP_ADVISOR
TELEMETRY_ANALYZER --> STRATEGY_AI
SETUP_ADVISOR --> TUNING_LOGIC
STRATEGY_AI --> TRACK_DATA
STRATEGY_AI --> SETUP_LIBRARY

MCP_API --> AI_ENGINE
MCP_WS --> AI_ENGINE
MCP_SSE --> AI_ENGINE

AI_ENGINE -->|"LLM Requests"| LLM_CONNECTOR
LLM_CONNECTOR ==>|"HTTPS"| OPENROUTER
LLM_CONNECTOR ==>|"HTTPS"| OPENAI
LLM_CONNECTOR ==>|"HTTPS"| ANTHROPIC

%% ===========================================================================
%% nginx Routing
%% ===========================================================================
NGINX_HTTP --> API_PROXY
NGINX_HTTPS --> API_PROXY
API_PROXY ==>|"/api/*"| MCP_API
API_PROXY ==>|"/ws"| MCP_WS
API_PROXY ==>|"/mcp/sse"| MCP_SSE
API_PROXY ==>|"Telemetry"| HTTP

NGINX_HTTP --> STATIC_SERVER
NGINX_HTTPS --> STATIC_SERVER
STATIC_SERVER ==> UI

%% ===========================================================================
%% Web UI Integration
%% ===========================================================================
SOCKETIO ==> STREAM_OVERLAY
SOCKETIO ==> DRV_VIEW
SOCKETIO ==> ENG_VIEW
SOCKETIO ==> STRATEGY_CENTER
SOCKETIO ==> VOICE_STRATEGY

STRATEGY_CENTER -->|"Chat Messages"| MCP_API
VOICE_STRATEGY -->|"Chat Messages"| MCP_API

%% ===========================================================================
%% Voice Integration
%% ===========================================================================
VOICE_STRATEGY --> PTT
PTT --> STT
STT -->|"Text"| VOICE_STRATEGY
VOICE_STRATEGY -->|"AI Response"| TTS
TTS -->|"Audio"| VOICE_STRATEGY

%% ===========================================================================
%% AI Client Integration
%% ===========================================================================
NGINX_HTTPS ==>|"SSE Stream"| CHATGPT
NGINX_HTTPS ==>|"SSE Stream"| CLAUDE
NGINX_HTTPS ==>|"MCP Protocol"| CURSOR
API_PROXY ==>|"REST/WebSocket"| CUSTOM_AI

CHATGPT -.->|"Ask about telemetry"| MCP_SSE
CLAUDE -.->|"Setup questions"| MCP_SSE
CURSOR -.->|"Strategy queries"| MCP_SSE

%% ===========================================================================
%% Low-Latency HUD Distribution
%% ===========================================================================
ZMQ_PUB ==> ZMQ_PROXY ==> HUD_SUB ==> HUD_QT
SOCKETIO ==> HUD_SOCKETIO ==> HUD_QT

