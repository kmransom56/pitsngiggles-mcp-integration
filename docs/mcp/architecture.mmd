%% ---------------------------------------------------------------------------
%% Pits N Giggles + MCP Integration - Complete Architecture
%% Docker-based deployment with F1 Race Engineer AI
%% ---------------------------------------------------------------------------
flowchart TB

%% ===========================================================================
%% External Systems
%% ===========================================================================
subgraph EXTERNAL[" External Systems"]
  direction TB
  F1_SIM[" F1 23/24/25 Game"]
  AI_CLIENTS[" AI Clients<br/>ChatGPT • Claude • Cursor"]
end

%% ===========================================================================
%% Docker Environment
%% ===========================================================================
subgraph DOCKER[" Docker Environment (f1-network)"]
  direction TB
  
  subgraph NGINX_CONTAINER[" Nginx Reverse Proxy Container"]
    direction TB
    NGINX[" nginx<br/>Host :9080/:9443 → 80/443"]
    SSL[" SSL/TLS<br/>Self-Signed + Production"]
    STATIC_FILES[" Static HTML Files<br/>Strategy Center, Voice, Dashboards"]
  end
  
  subgraph MCP_CONTAINER[" MCP Server Container"]
    direction TB
    MCP_APP[" FastAPI Server<br/>Port 8765"]
    F1_AGENT[" F1 Race Engineer<br/>AI Agent"]
    LLM_CLIENT[" LLM Client<br/>OpenRouter/OpenAI/Anthropic"]
    TELEMETRY_ANALYZER[" Telemetry Analyzer<br/>Setup Diagnosis"]
    MCP_TOOLS[" 10 MCP Tools<br/>Specialized Functions"]
  end
  
  subgraph PNG_OPTIONAL[" Pits N Giggles (Optional in Docker)"]
    direction TB
    PNG_SERVER[" Telemetry Server<br/>Port 4768"]
    PNG_COMPUTE[" Computation Engine<br/>Live Race Data"]
    PNG_STATE[" State Manager<br/>Session Storage"]
  end
end

%% ===========================================================================
%% Host System (Alternative to Docker)
%% ===========================================================================
subgraph HOST[" Host System"]
  direction TB
  PNG_HOST[" Pits N Giggles<br/>host:4768"]
  BROWSER[" Web Browser"]
end

%% ===========================================================================
%% Frontend Applications
%% ===========================================================================
subgraph FRONTEND[" Web Frontend (Served by Nginx)"]
  direction TB
  STRATEGY_CENTER[" Strategy Center<br/>AI Chat Interface<br/>3 AI Modes"]
  VOICE_STRATEGY[" Voice Strategy Center<br/>Speech-to-Text (Web API)<br/>Text-to-Speech (Web API)<br/>Push-to-Talk (Space Key)"]
  ENG_VIEW[" Engineer Dashboard<br/>Classic Telemetry"]
  DRV_VIEW[" Driver Dashboard<br/>Classic Telemetry"]
  STREAM_OVERLAY[" Stream Overlay<br/>OBS Integration"]
end

%% ===========================================================================
%% LLM Services
%% ===========================================================================
subgraph LLM_SERVICES[" LLM Services (Cloud)"]
  direction TB
  OPENROUTER[" OpenRouter<br/>Multi-Model Gateway<br/>GPT-4o-mini, Claude 3.5, Llama 3.1"]
  OPENAI[" OpenAI<br/>GPT-4, GPT-4o<br/>GPT-4o-mini"]
  ANTHROPIC[" Anthropic<br/>Claude 3.5 Sonnet<br/>Claude 3 Opus"]
  GOOGLE[" Google<br/>Gemini Pro 1.5"]
end

%% ===========================================================================
%% Data Flow: Game to Telemetry
%% ===========================================================================
F1_SIM ==>|UDP Packets<br/>F1 Telemetry| PNG_HOST
F1_SIM -.->|UDP Packets| PNG_SERVER

%% ===========================================================================
%% Host Telemetry Flow
%% ===========================================================================
PNG_HOST ==>|Socket.IO<br/>Telemetry Stream| NGINX

%% ===========================================================================
%% Docker Internal Flow
%% ===========================================================================
PNG_SERVER ==> PNG_COMPUTE ==> PNG_STATE
PNG_STATE -.->|Socket.IO| NGINX

%% ===========================================================================
%% Nginx Routing
%% ===========================================================================
NGINX ==>|"/mcp/*"<br/>POST /mcp/chat, WS /mcp/ws| MCP_APP
NGINX ==>|"/telemetry/*"<br/>→ PNG :4768| PNG_HOST
NGINX ==>|"/"<br/>Frontend Pages| FRONTEND
NGINX ==>|"/health"| MCP_APP

%% ===========================================================================
%% MCP Server Internal
%% ===========================================================================
MCP_APP ==> MCP_TOOLS
MCP_TOOLS ==> TELEMETRY_ANALYZER
TELEMETRY_ANALYZER ==> F1_AGENT
F1_AGENT ==> LLM_CLIENT

%% ===========================================================================
%% LLM Integration
%% ===========================================================================
LLM_CLIENT ==>|HTTPS<br/>Chat Completion<br/>Context + Telemetry| OPENROUTER
LLM_CLIENT -.->|Direct API<br/>Optional| OPENAI
LLM_CLIENT -.->|Via OpenRouter| ANTHROPIC
LLM_CLIENT -.->|Via OpenRouter| GOOGLE

%% ===========================================================================
%% Browser Connections
%% ===========================================================================
BROWSER ==>|HTTPS<br/>https://localhost:9443| NGINX
NGINX ==>|Serve HTML| STRATEGY_CENTER
NGINX ==>|Serve HTML| VOICE_STRATEGY
NGINX ==>|Serve HTML| ENG_VIEW
NGINX ==>|Serve HTML| DRV_VIEW
NGINX ==>|Serve HTML| STREAM_OVERLAY

%% ===========================================================================
%% Strategy Center Integration
%% ===========================================================================
STRATEGY_CENTER ==>|POST /mcp/chat<br/>via nginx /mcp/| MCP_APP
STRATEGY_CENTER ==>|WebSocket /mcp/ws| MCP_APP
STRATEGY_CENTER ==>|Telemetry HTML/API<br/>/telemetry/ or :4768| NGINX

%% ===========================================================================
%% Voice Integration (Browser-Based)
%% ===========================================================================
VOICE_STRATEGY ==>|Push-to-Talk (Space)<br/>Web Speech API STT<br/>Local Processing| MCP_APP
MCP_APP ==>|AI Response Text| VOICE_STRATEGY
VOICE_STRATEGY -.->|Web Speech API TTS<br/>Local Synthesis| BROWSER

%% ===========================================================================
%% AI Client Integration (MCP Protocol)
%% ===========================================================================
AI_CLIENTS ==>|SSE GET /telemetry/mcp<br/>(PNG GET /mcp)| NGINX
NGINX ==>|strip /telemetry/ → :4768| PNG_HOST
PNG_HOST ==>|SSE event stream| AI_CLIENTS

%% ===========================================================================
%% Response Flow
%% ===========================================================================
OPENROUTER ==>|AI Response<br/>Setup Recommendations| LLM_CLIENT
LLM_CLIENT ==> F1_AGENT
F1_AGENT ==>|Formatted Response<br/>+ Analysis<br/>+ Recommendations<br/>+ Telemetry Insights| MCP_APP
MCP_APP ==>|JSON /mcp/chat| NGINX
NGINX ==>|HTTPS| STRATEGY_CENTER
NGINX ==>|HTTPS + Voice| VOICE_STRATEGY

